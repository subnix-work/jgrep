# Maintainer: Tino Gohl <tuvbunn2@googlemail.com>
pkgname=jgrep
pkgver=1.1.0
pkgrel=1
pkgdesc="grep for JSON — filter and search JSON files using jq expressions"
arch=('x86_64')
url="https://github.com/subnix-work/jgrep"
license=('Apache-2.0')
makedepends=('docker' 'maven')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/subnix-work/jgrep/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "${srcdir}/jgrep-${pkgver}/jgrep"

    # Ensure Docker is running
    if ! docker info &>/dev/null; then
        echo "Docker is not running. Please start Docker and retry."
        return 1
    fi

    ./mvnw package -Pnative -Dquarkus.native.container-build=true \
        --no-transfer-progress \
        -Dmaven.test.skip=true
}

package() {
    cd "${srcdir}/jgrep-${pkgver}/jgrep"
    install -Dm755 target/jgrep "${pkgdir}/usr/bin/jgrep"
    install -Dm644 ../LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
