# Maintainer: Tino Gohl <tuvbunn2@googlemail.com>
pkgname=ygrep
pkgver=1.3.0
pkgrel=1
pkgdesc="grep for YAML — filter structured files using jq expressions"
arch=('x86_64')
url="https://github.com/subnix-work/jgrep"
license=('Apache-2.0')
makedepends=('docker' 'maven' 'java-environment=25')
source=("jgrep-${pkgver}.tar.gz::https://github.com/subnix-work/jgrep/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "${srcdir}/jgrep-${pkgver}/ygrep"

    # Ensure Docker is running
    if ! docker info &>/dev/null; then
        echo "Docker is not running. Please start Docker and retry."
        return 1
    fi

    ./mvnw package -Pnative -Dquarkus.native.container-build=true \
        --no-transfer-progress \
        -Dmaven.test.skip=true
}

package() {
    cd "${srcdir}/jgrep-${pkgver}/ygrep"
    install -Dm755 "target/ygrep-${pkgver}-runner" "${pkgdir}/usr/bin/ygrep"
    install -Dm644 ../LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
